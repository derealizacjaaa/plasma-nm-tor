+void NetworkStatus::updateVpn()
+{
+    bool available = false;
+    bool active = false;
+    QString name;
+    QString ipv4;
+    QString connectionPath;
+    QString devicePath;
+
+    // Prefer an active (or activating) VPN/WireGuard connection
+    for (const NetworkManager::ActiveConnection::Ptr &ac : NetworkManager::activeConnections()) {
+        if (!isVpnLikeType(ac->type())) {
+            continue;
+        }
+
+        connect(ac.data(), &NetworkManager::ActiveConnection::stateChanged, this, &NetworkStatus::updateVpn, Qt::UniqueConnection);
+        connect(ac.data(), &NetworkManager::ActiveConnection::ipV4ConfigChanged, this, &NetworkStatus::updateVpn, Qt::UniqueConnection);
+
+        if (ac->state() != NetworkManager::ActiveConnection::Activated && ac->state() != NetworkManager::ActiveConnection::Activating) {
+            continue;
+        }
+
+        available = true;
+        active = true;
+        NetworkManager::Connection::Ptr connection = ac->connection();
+        name = connection ? connection->name() : ac->id();
+        connectionPath = connection ? connection->path() : QString();
+        if (!ac->devices().isEmpty()) {
+            devicePath = ac->devices().first();
+        }
+        const auto addresses = ac->ipV4Config().addresses();
+        if (!addresses.isEmpty()) {
+            ipv4 = addresses.first().ip().toString();
+        }
+        break;
+    }
+
+    // Otherwise fall back to the first configured VPN/WireGuard profile
+    if (!active) {
+        for (const NetworkManager::Connection::Ptr &con : NetworkManager::listConnections()) {
+            if (!con->settings() || !isVpnLikeType(con->settings()->connectionType())) {
+                continue;
+            }
+            available = true;
+            name = con->name();
+            connectionPath = con->path();
+            break;
+        }
+    }
+
+    if (m_vpnAvailable != available || m_vpnActive != active || m_vpnName != name || m_vpnIpv4 != ipv4 || m_vpnConnectionPath != connectionPath
+        || m_vpnDevicePath != devicePath) {
+        m_vpnAvailable = available;
+        m_vpnActive = active;
+        m_vpnName = name;
+        m_vpnIpv4 = ipv4;
+        m_vpnConnectionPath = connectionPath;
+        m_vpnDevicePath = devicePath;
+        Q_EMIT vpnChanged();
+    }
+}
