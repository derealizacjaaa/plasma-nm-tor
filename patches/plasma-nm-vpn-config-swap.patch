+import QtQuick
+import QtQuick.Layouts
+
+import org.kde.kirigami as Kirigami
+import org.kde.kcmutils
+import org.kde.kirigamiaddons.formcard as FormCard
+import org.kde.plasma.networkmanagement as PlasmaNM
+
+SimpleKCM {
+    id: root
+
+    leftPadding: 0
+    rightPadding: 0
+    topPadding: Kirigami.Units.gridUnit
+    bottomPadding: Kirigami.Units.gridUnit
+
+    data: [
+        PlasmaNM.VpnConfigs {
+            id: vpnConfigs
+        },
+
+        Connections {
+            target: vpnConfigs
+
+            function onApplyFailed(message) {
+                errorMessage.text = message;
+                errorMessage.visible = true;
+            }
+
+            function onApplied(uuid) {
+                errorMessage.visible = false;
+            }
+        }
+    ]
+
+    header: Kirigami.InlineMessage {
+        id: errorMessage
+
+        type: Kirigami.MessageType.Error
+        position: Kirigami.InlineMessage.Position.Header
+        showCloseButton: true
+        visible: false
+    }
+
+    Component.onCompleted: vpnConfigs.refresh()
+
+    ColumnLayout {
+        spacing: 0
+
+        Kirigami.PlaceholderMessage {
+            Layout.fillWidth: true
+            Layout.topMargin: Kirigami.Units.gridUnit * 4
+            visible: vpnConfigs.connections.length === 0
+            icon.name: "network-vpn"
+            text: i18n("No VPN connections")
+            explanation: i18n("Add or import a VPN connection in Wi-Fi & Networking first — this page swaps configuration files into existing connections.")
+        }
+
+        FormCard.FormCard {
+            visible: vpnConfigs.connections.length > 0 && vpnConfigs.configs.length === 0
+
+            FormCard.FormTextDelegate {
+                text: i18n("No configuration files found")
+                description: i18n("Put .ovpn, .conf, .wg or .pcf files into ~/.config/plasma-nm-vpn-configs or /etc/plasma-nm/vpn-configs and they will show up here.")
+            }
+        }
+
+        Repeater {
+            model: vpnConfigs.configs.length > 0 ? vpnConfigs.connections : []
+
+            delegate: ColumnLayout {
+                id: connectionSection
+
+                required property var modelData
+
+                Layout.fillWidth: true
+                spacing: 0
+
+                FormCard.FormHeader {
+                    title: connectionSection.modelData.active
+                        ? i18nc("%1 is a VPN connection name", "%1 — connected", connectionSection.modelData.name)
+                        : connectionSection.modelData.name
+                }
+
+                FormCard.FormCard {
+                    Repeater {
+                        model: vpnConfigs.configs
+
+                        delegate: FormCard.FormButtonDelegate {
+                            id: fileDelegate
+
+                            required property var modelData
+
+                            readonly property bool isCurrent: modelData.path === connectionSection.modelData.currentConfig
+
+                            text: modelData.name
+                            description: modelData.path
+                            icon.name: isCurrent ? "checkmark" : "document-replace"
+                            enabled: !vpnConfigs.busy
+
+                            onClicked: vpnConfigs.apply(fileDelegate.modelData.path, connectionSection.modelData.uuid)
+                        }
+                    }
+                }
+            }
+        }
+    }
+}
