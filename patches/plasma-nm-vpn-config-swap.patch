+
+#ifndef PLASMA_NM_VPN_CONFIGS_H
+#define PLASMA_NM_VPN_CONFIGS_H
+
+#include <QFileSystemWatcher>
+#include <QObject>
+#include <QVariantList>
+
+#include <qqmlregistration.h>
+
+typedef struct _NMClient NMClient;
+typedef struct _NMConnection NMConnection;
+typedef struct _NMRemoteConnection NMRemoteConnection;
+typedef struct _GObject GObject;
+typedef struct _GAsyncResult GAsyncResult;
+
+/**
+ * On-the-fly VPN configuration swapping for the applet.
+ *
+ * Watches ~/.config/plasma-nm-vpn-configs and /etc/plasma-nm/vpn-configs for
+ * VPN configuration files (.ovpn, .conf, .wg, .pcf). apply() imports the
+ * chosen file through NetworkManager's own VPN editor plugins (the same
+ * mechanism `nmcli connection import` uses; WireGuard goes through libnm
+ * directly), overwrites the settings of an existing connection while keeping
+ * its name and UUID, and reactivates the tunnel.
+ */
+class VpnConfigs : public QObject
+{
+    Q_OBJECT
+    QML_ELEMENT
+
+    /** list of {name, path} maps, one per discovered configuration file */
+    Q_PROPERTY(QVariantList configs READ configs NOTIFY configsChanged)
+    /** an apply() is in flight */
+    Q_PROPERTY(bool busy READ busy NOTIFY busyChanged)
+
+public:
+    explicit VpnConfigs(QObject *parent = nullptr);
+    ~VpnConfigs() override;
+
+    QVariantList configs() const;
+    bool busy() const;
+
+    /** rescan the config directories (call when the item expands) */
+    Q_INVOKABLE void refresh();
+    /** whether a connection of this NM type can have its config swapped */
+    Q_INVOKABLE bool isSwappable(int type) const;
+    /** path of the config file last applied to the connection, if recorded */
+    Q_INVOKABLE QString currentConfig(const QString &uuid);
+    /** import filePath and swap it into the connection identified by uuid */
+    Q_INVOKABLE void apply(const QString &filePath, const QString &uuid);
+
+Q_SIGNALS:
+    void configsChanged();
+    void busyChanged();
+    /** the swap finished and the connection (possibly re-created) is activating */
+    void applied(const QString &uuid);
+    void applyFailed(const QString &message);
+
+private:
+    void scan();
+    void setBusy(bool busy);
+    NMClient *client();
+    NMConnection *importFile(const QString &filePath, QString &errorOut) const;
+    void finishApply(const QString &uuid, const QString &connectionPath, bool wasActive);
+    void fail(const QString &message);
+    void notifySuccess(const QString &name);
+
+    // glib async callbacks (GAsyncReadyCallback-compatible)
+    static void update2Callback(GObject *source, GAsyncResult *result, void *userData);
+    static void deleteCallback(GObject *source, GAsyncResult *result, void *userData);
+    static void addCallback(GObject *source, GAsyncResult *result, void *userData);
+
+    QFileSystemWatcher m_watcher;
+    QStringList m_dirs;
+    QVariantList m_configs;
+    NMClient *m_client = nullptr;
+    bool m_busy = false;
+};
+
+#endif // PLASMA_NM_VPN_CONFIGS_H
